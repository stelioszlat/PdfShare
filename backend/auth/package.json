{
  "name": "auth",
  "version": "1.0.0",
  "description": "",
  "main": "auth.js",
  "scripts": {
    "start": "node auth.js",
    "dev": "nodemon auth.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "auth/**/*.js",
      "!auth/**/node_modules/**",
      "!auth/**/test/**"
    ],
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "chai": "^4.3.7",
    "jest": "^30.2.0",
    "mocha": "^10.2.0",
    "nodemon": "^2.0.16",
    "sinon": "^15.0.3",
    "supertest": "^7.1.4",
    "swagger-ui-express": "^4.5.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.1",
    "brcypt": "^1.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "express": "^4.18.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^6.4.2",
    "morgan": "^1.10.0",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0"
  }
}
